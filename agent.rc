#!/bin/rc
# plan9-agent -- a tiny interactive coding agent for Plan 9 / 9front.
#
# Reads one task per line from stdin, so it composes like any unix filter:
#   agent               (interactive: type tasks; ctrl-D or 'quit' to exit)
#   echo TASK | agent   /   agent <tasks.txt   /   agent <fifo   (daemon)
# For each task the model issues ONE rc command at a time inside a code fence; we
# run it sandboxed (under a timeout) and feed the real output back, until it
# answers with a DONE message. Then it reads the next task.
#
# Talks to an OpenAI-style chat endpoint (here a Mac-side proxy to Claude).
# The Plan 9 reference is loaded from plan9.txt. Trails mirror to the Mac (/up).

oifs=$ifs
# Knobs -- set any as ordinary rc variables BEFORE running; rc exports them to
# the child, so they override the defaults below. Set them on their own lines
# (rc rejects an assignment on the right of a pipe), then pipe or redirect, e.g.
#   model=claude-opus-4-8
#   maxtok=8192
#   rc agent.rc <tasks
# argv is left free: stdin is the task input.
if(~ $#model 0){ model=claude-haiku-4-5-20251001 }	# which Claude the proxy calls
if(~ $#keep 0){ keep=12 }	# how many recent messages to send (plus the task) -- bounds request size
if(~ $#steps 0){ steps=16 }	# max model<->harness round-trips per task before giving up
if(~ $#maxtok 0){ maxtok=4096 }	# max tokens per model reply (passed through to the proxy)
if(~ $#base 0){ base=http://10.0.2.2:8000 }	# dev-helper base URL (devserver): the /plan9.txt fetch and /up upload use it. 10.0.2.2 = the QEMU host as seen from inside the guest; change if the helper runs elsewhere
if(~ $#url 0){ url=$base^/claude }	# chat endpoint: the helper's /claude proxy by default; set to an https provider URL for bridge-less (direct=yes)
if(~ $#direct 0){ direct=no }	# yes = POST straight to $url over https with a Bearer key -- no proxy (needs an OpenAI-shaped provider, e.g. OpenRouter)
if(~ $#keyfile 0){ keyfile=$home/.llmkey }	# direct mode: file holding the API key. Kept in $home so the per-command sandbox masks it FROM the agent
hidefile=/tmp/agent.hide	# file listing dirs to mask (one path/line); re-read each command, editable live from any window
ctxdir=/tmp/agent/context	# system prompt is composed from every file in here (name order); edit/add files to change it
histfile=/tmp/agent/history	# append-only, timestamped record of every message (NOT trimmed, NOT sent); grep to recall

sysbase='You are an agent on a Plan 9 (9front) computer using the rc shell.

Work ONE STEP AT A TIME, and ACTUALLY run each step -- never fake it:
- To run a command, reply with brief reasoning then EXACTLY ONE command inside a fenced block tagged run, like:
```run
ls /bin
```
- Include EXACTLY ONE ```run block, and put NOTHING after it. If you write more than one, only the FIRST runs and the rest are thrown away -- so commit to a single command. Do NOT predict or write what the output will be. End your message at the run block and wait.
- Do NOT re-run an expensive or large command to see a different slice of its output. Run it ONCE into a file (cmd >/tmp/out), then read pieces from the file (sed Nq, sed -n A,Bp, grep). One traversal, many looks.
- Do NOT put the word DONE in a message that contains a ```run block.
- You will then be shown the REAL output. Only after you have seen real output do you continue.
- If a command errors or an approach does not work, do NOT re-run the same command or a near-identical variant -- change strategy. If two genuinely different approaches both fail, the system likely lacks that capability: STOP and tell the user so (with no run block), rather than looping. Never repeat a command that just failed unchanged.
- Do NOT assert what a command IS or DOES from its name or a guess (e.g. do not assume "abaco" is a calculator because it sounds like "abacus" -- it is a web browser). Verify: run it and read real output, or check with whatis NAME / man NAME. Only claim a tool works after you have SEEN it work.
- Do NOT modify shared system files (under /rc, /sys, /lib, /bin, /dev) to satisfy a per-user request -- those affect the whole system. Per-user settings belong in the user home (e.g. $home/lib/profile). Your home is sandboxed and appears empty, so if a task needs the user home and it is empty/inaccessible, do NOT reach for a system file instead: tell the user it is sandboxed and let them apply the change (or unmask home).

Most commands should be text commands that print and exit. To run a GRAPHICAL or INTERACTIVE program (one that opens a window or waits for input), launch it in its own window: window PROG -- this opens a new rio window and returns immediately, so it will NOT hang the loop. Never run a graphical or interactive program directly without window, as that hangs. Because window PROG returns immediately, you CANNOT see the output of a graphical program -- opening a window is NOT evidence the task is done, so never report success on the strength of having launched one. Prefer a text tool you can actually verify (e.g. for arithmetic, hoc reads an expression and prints the answer). If a program is an rc script, cat it to see how it works. If unsure about a command or its options, run: man NAME.

To give your final answer, or to ask the user a question, reply with NO ```run block. You MAY quote code or output using ordinary fences (```c, ```, and so on) -- those are shown to the user, never executed; only a ```run block runs. That message is shown to the user and ends your turn; the user can then reply with more.

You run in a restricted per-command namespace: your working directory is /tmp -- create and compile files there. Your home directory is hidden and appears empty. Each command runs in a fresh namespace, so changing where you are does not persist between commands.

A full record of this conversation is kept at /tmp/agent/history. If you need something from earlier that is no longer in view, grep that file, e.g. grep PATTERN /tmp/agent/history.

A reference for this system follows.'

fn esc {	# print file $1 as an escaped JSON string body (no surrounding quotes)
	awk 'BEGIN{ORS=""}
	     { gsub(/\t/," "); gsub(/[^ -~]/,"")	# tabs->space, then drop control/binary bytes (keeps JSON valid)
	       gsub(/\\/,"\\\\"); gsub(/"/,"\\\"")
	       if(NR>1)printf "\\n"; printf "%s",$0 }' $1
}

fn addmsg {	# $1=role  $2=file -> append to the sent messages AND the timestamped history record
	{ echo -n '{"role":"'^$1^'","content":"'; esc $2; echo -n '"}'; echo } >>/tmp/messages
	{ echo '===' $1 '@' `{date} '==='; cat $2; echo } >>$histfile	# append-only, greppable, never trimmed
}

fn upload {
	ifs=(); b=`{cat $1}; ifs=$oifs
	hget -p $b $base^/up >/dev/null
}

fn dbg {
	{	echo '=== RAW RESPONSE ==='; cat /tmp/resp.json
		echo; echo '=== MESSAGES ==='; cat /tmp/messages } >/tmp/dbg
	upload /tmp/dbg
}

fn runcmd {	# run /tmp/cmd in a private namespace, under a 15s timeout; feed back <=40 lines
	echo; echo '### runs (sandboxed):'; cat /tmp/cmd; echo
	hide=`{cat $hidefile}		# re-read the policy each turn, so live edits to $hidefile take effect
	# @{} forks the namespace, so the binds below are LOCAL to this command and
	# vanish when it exits -- a fresh sandbox every turn, enforced by the kernel.
	# We mask each dir in $hide (your home) behind an empty dir and pin the cwd to
	# the /tmp scratch area. exec makes the command BE this process, so the
	# timeout's kill-note lands on it directly.
	@{
		for(d in $hide){ bind /tmp/.empty $d >[2]/dev/null }
		cd /tmp
		exec rc /tmp/cmd
	} </dev/null >/tmp/out >[2=1] &
	p=$apid
	{ sleep 15; echo kill >/proc/$p/note } >[2]/dev/null &
	w=$apid
	wait $p
	echo kill >/proc/$w/note >[2]/dev/null		# stop the watchdog if cmd finished first
	echo '### output:'; cat /tmp/out
	sed 40q /tmp/out >/tmp/outcap			# cap what the model sees, so it cannot bloat the request
	if(test `{wc -l </tmp/out} -gt 40){
		echo '...[output truncated to 40 lines; use grep or sed Nq to narrow it]' >>/tmp/outcap
	}
	addmsg assistant /tmp/content
	{ echo 'Command output:'; cat /tmp/outcap } >/tmp/usermsg
	addmsg user /tmp/usermsg
}

fn buildsys {	# compose /tmp/sys (the system prompt) from every file in $ctxdir, in name order
	>/tmp/sys
	for(f in `{ls $ctxdir}){ cat $f >>/tmp/sys; echo >>/tmp/sys }
}

# seed the context dir once, from the built-in prompt + the fetched reference. after that the
# files in $ctxdir are the source of truth: edit them (or have a model write them) to change the
# agent's context. rm -r $ctxdir to reseed from the defaults below.
hget $base^/plan9.txt >/tmp/plan9
if(! test -d $ctxdir){
	mkdir -p $ctxdir
	echo $sysbase >$ctxdir/00-system
	cp /tmp/plan9 $ctxdir/10-plan9
}
buildsys

mkdir -p /tmp/.empty	# the empty dir we bind over hidden paths in each command's sandbox
echo '===== session started @ '`{date}' =====' >>$histfile	# open a new block in the append-only record
if(! test -f $hidefile){
	echo $home >$hidefile	# seed the default sandbox policy on first run (your edits then persist)
}

echo 'plan9-agent ready -- reading tasks from stdin, one per line (quit or ctrl-D to end).'
echo 'knobs: model '^$model^'  keep '^$keep^'  steps '^$steps^'  maxtok '^$maxtok
echo -n 'sandbox masks (edit '^$hidefile^' live to change): '; cat $hidefile
echo 'context (edit/add files in '^$ctxdir^' to shape the prompt):'; ls $ctxdir
>/tmp/messages		# the conversation PERSISTS across prompts (so follow-ups have context)

while(~ 1 1){
	echo
	echo -n 'agent> '
	if(! read >/tmp/task){		# EOF on stdin (pipe closed or ctrl-D): exit cleanly, so the agent composes as a filter
		echo bye.
		exit 0
	}
	if(~ `{cat /tmp/task} quit exit){
		echo bye.
		exit 0
	}
	# ignore an empty line (read leaves just a newline = 1 byte)
	if(test `{wc -c </tmp/task} -gt 1){
		addmsg user /tmp/task		# append the new task; earlier turns stay for context
		buildsys		# recompose the prompt from $ctxdir each turn, so live edits to context apply
		echo no >/tmp/done

		for(i in `{seq 1 $steps}){
			if(~ `{cat /tmp/done} no){
				# trim history: keep the first message + the most recent ~12
				awk '{l[NR]=$0} END{n='^$keep^'; print l[1]; s=NR-n+1; if(s<2)s=2; for(i=s;i<=NR;i++)print l[i]}' /tmp/messages >/tmp/hist

				# build request: system message + the (comma-joined) trimmed history
				{
					echo -n '{"model":"'^$model^'","max_tokens":'^$maxtok^',"messages":[{"role":"system","content":"'
					esc /tmp/sys
					echo -n '"},'
					awk 'NR>1{printf ","} {printf "%s",$0}' /tmp/hist
					echo -n '],"stream":false}'
				} >/tmp/req.json

				>/tmp/resp.json
					{ ifs=(); rq=`{cat /tmp/req.json}; ifs=$oifs
						if(~ $direct yes){
							key=`{cat $keyfile}
							hget -P -r 'Content-Type: application/json' -r 'Authorization: Bearer '^$key $url </tmp/req.json >/tmp/resp.json
						}
						if not {
							hget -p $rq $url >/tmp/resp.json
						}
					} &	# model call runs in the background under a timeout, so a network stall can't hang the agent
					sp=$apid
					{ sleep 90; echo kill >/proc/$sp/note } >[2]/dev/null &
					sw=$apid
					wait $sp
					echo kill >/proc/$sw/note >[2]/dev/null	# cancel the watchdog if the call returned first

				# pull the message content value robustly: find "content":" then read the JSON
					# string up to the first UNescaped quote. Works whatever fields follow it, so a
					# raw provider reply (refusal/logprobs/usage siblings) parses like the proxy's.
					awk '{ full = full $0 }
					     END{ m = "\"content\":\""; i = index(full, m)
					          if(i == 0) exit
					          s = substr(full, i + length(m)); p = 1
					          while(1){ q = index(substr(s, p), "\"")
					                    if(q == 0){ printf "%s", s; exit }
					                    a = p + q - 1; b = 0
					                    while(a-1-b >= 1 && substr(s, a-1-b, 1) == "\\") b = b + 1
					                    if(b % 2 == 0){ printf "%s", substr(s, 1, a-1); exit }
					                    p = a + 1 } }' /tmp/resp.json >/tmp/raw
				awk '{ gsub(/\\\\/,"\001")	# protect escaped backslashes first
				       gsub(/\\u003c/,"<"); gsub(/\\u003e/,">"); gsub(/\\u0026/,"\\&")
				       gsub(/\\"/,"\""); gsub(/\\t/,"\t"); gsub(/\\n/,"\n")
				       gsub(/\001/,"\\"); print }' /tmp/raw >/tmp/content	# restore as single backslashes

				if(grep '^```run' /tmp/content >/dev/null){
					# the model issued a command (a ```run block): run just that block.
					# ordinary ```/```c fences are quoted code in an ANSWER -- never run.
					awk '/^```run/{f=1; next} f && /^```/{exit} f{print}' /tmp/content >/tmp/cmd
					runcmd
				}
				if not {
					# NO command -- the model is talking to you (answer or question).
					# Show it, keep it in history, and hand control back to the prompt.
					echo; echo '### agent:'; sed 's/^DONE[ :]*//' /tmp/content; echo
					addmsg assistant /tmp/content
					echo yes >/tmp/done
					dbg
				}
			}
		}

		if(~ `{cat /tmp/done} no){
			echo '(hit the step limit -- type more to continue, or a new task)'
			dbg
		}
	}
}
